# ZK Email Recovery API
# Proxies requests to the ZK Email hosted/generic account-recovery relayer.
# Does NOT send proof emails directly. The ZK Email relayer handles email sending/receiving/ZK proof generation.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

ZK_EMAIL_RELAYER_URL=https://auth-base-sepolia-staging.prove.email/api
ZK_EMAIL_RELAYER_API_KEY=
ZK_EMAIL_PROOF_MODE=per_chain_hosted
ZK_EMAIL_ACCEPTANCE_TEMPLATE_IDX=0
ZK_EMAIL_RECOVERY_TEMPLATE_IDX=1

PORT=3001
