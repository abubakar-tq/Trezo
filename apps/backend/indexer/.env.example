# RPC endpoints
PONDER_ANVIL_RPC_URL=http://192.168.100.68:8545
PONDER_BASE_FORK_RPC_URL=http://192.168.100.68:8545

# Ponder Postgres database (separate from Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/indexer

# Ponder schema namespace — Ponder reads this env var natively (no config wiring needed)
PONDER_DATABASE_SCHEMA=indexer_v1

# Sync worker: Supabase service-role credentials (NEVER in Ponder process)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sync worker poll interval in milliseconds
SYNC_WORKER_POLL_INTERVAL_MS=2000
