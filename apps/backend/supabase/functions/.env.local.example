# Local Edge Function custom secrets for recovery development.
# Copy to: apps/backend/supabase/functions/.env.local
#
# scripts/infra-up.sh will inject the local SUPABASE_URL,
# SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY automatically into a
# generated runtime env file before serving edge functions.
#
# Required for submit-recovery-operation:
# Use a funded local Anvil key. Do not commit real private keys.
RECOVERY_RELAYER_PRIVATE_KEY=0x

# Optional but recommended override for local chain 31337.
# Since edge runtime is in Docker, host.docker.internal is safer than localhost.
RECOVERY_RPC_URL_31337=http://host.docker.internal:8545

# Optional host alias for localhost-like RPC URLs.
RECOVERY_LOCALHOST_ALIAS=host.docker.internal
