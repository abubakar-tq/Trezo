# Optional: remote-to-local user data sync settings for infra startup.
# Copy to apps/backend/supabase/.env.sync.local (gitignored)
#
# Source (production) Supabase project:
REMOTE_SUPABASE_URL=https://your-project-ref.supabase.co
REMOTE_SUPABASE_SERVICE_ROLE_KEY=your-remote-service-role-key
SYNC_USER_EMAIL=you@example.com

# Optional alternative if you prefer user id:
# SYNC_USER_ID=00000000-0000-0000-0000-000000000000
