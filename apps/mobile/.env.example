# Trezo Wallet Environment Configuration
# =========================================
# Copy this file to `.env` and fill in your own values before running the app.

# =========================================
# Supabase Configuration
# =========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-anon-key

# =========================================
# Moralis Data API
# =========================================
# Get your API key from: https://admin.moralis.io/settings/api-keys
MORALIS_API_KEY=your-moralis-data-api-key

# =========================================
# Passkey Configuration (WebAuthn)
# =========================================
# Relying Party ID - MUST be a real domain you own
# Examples: your-domain.com OR username.github.io
# Requires .well-known/assetlinks.json (Android) and apple-app-site-association (iOS)
EXPO_PUBLIC_PASSKEY_RP_ID=your-domain.com
EXPO_PUBLIC_PASSKEY_RP_NAME="Your Wallet Name"

# =========================================
# RPC URLs
# =========================================
# Ethereum Sepolia Testnet
# Get free RPC from: https://www.quicknode.com or https://alchemy.com
EXPO_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
EXPO_PUBLIC_SEPOLIA_ENTRYPOINT=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_SEPOLIA_ACCOUNT_FACTORY=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_SEPOLIA_PROXY_FACTORY=
EXPO_PUBLIC_SEPOLIA_ACCOUNT_IMPL=
EXPO_PUBLIC_SEPOLIA_PASSKEY_VALIDATOR=

# Local Anvil (for development)
EXPO_PUBLIC_ANVIL_RPC_URL=http://localhost:8545

# Ethereum Mainnet (Optional)
# EXPO_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# zkSync Era Mainnet (Optional)
# EXPO_PUBLIC_ZKSYNC_MAINNET_RPC_URL=https://mainnet.era.zksync.io

# zkSync Sepolia Testnet (Optional)
# EXPO_PUBLIC_ZKSYNC_SEPOLIA_RPC_URL=https://sepolia.era.zksync.dev

# =========================================
# Development Settings
# =========================================
# Enable Supabase debugging logs (optional)
# SUPABASE_LOG_LEVEL=debug

# =========================================
# Email Recovery — ZK Email Relayer
# =========================================
# ZK Email hosted relayer URL. Sends/receives guardian emails and generates ZK proofs.
# The hosted relayer is available on Base Sepolia (chain 84532).
#
# For local Anvil development, leave commented out — the app uses MockZkEmailRelayer automatically
# when this is not set (defaults to mock://local).
#
# For testnet (Base Sepolia), use the ZK Email staging relayer:
EXPO_PUBLIC_ZK_EMAIL_RELAYER_URL=https://auth-base-sepolia-staging.prove.email/api
# Optional API key for the ZK Email relayer (if required by your deployment):
# EXPO_PUBLIC_ZK_EMAIL_RELAYER_API_KEY=
# Proof mode: per_chain_hosted (one proof per guardian per chain) or reusable (one proof per guardian):
EXPO_PUBLIC_ZK_EMAIL_PROOF_MODE=per_chain_hosted
# Template indices from the EmailRecoveryCommandHandler:
EXPO_PUBLIC_ZK_EMAIL_ACCEPTANCE_TEMPLATE_IDX=0
EXPO_PUBLIC_ZK_EMAIL_RECOVERY_TEMPLATE_IDX=1
#
# ZK Email deployed contracts on Base Sepolia (for reference):
#   EmailRecoveryUniversalFactory: 0x5d50382D2f1C94268b784A69c99DEA7F6Babd2E6
#   UniversalEmailRecoveryModule:  0x636632FA22052d2a4Fb6e3Bab84551B620b9C1F9
#   RecoveryController Proxy:      0xBBaE39b5Cd43C02BF7418bf2B21133780c84a355
