# Trezo Wallet environment configuration
# Copy this file to `.env` and fill in the values before running the app.

# Supabase API credentials (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-anon-key

# Moralis Data API key (used for market data)
MORALIS_API_KEY=your-moralis-data-api-key

# Optional: enable Supabase debugging logs in development
# SUPABASE_LOG_LEVEL=debug
