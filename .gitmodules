[submodule "contracts/lib/openzeppelin-contracts"]
	path = contracts/lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts
[submodule "contracts/lib/openzeppelin-contracts-upgradeable"]
	path = contracts/lib/openzeppelin-contracts-upgradeable
	url = https://github.com/OpenZeppelin/openzeppelin-contracts-upgradeable
[submodule "contracts/lib/account-abstraction"]
	path = contracts/lib/account-abstraction
	url = https://github.com/eth-infinitism/account-abstraction
[submodule "contracts/lib/foundry-devops"]
	path = contracts/lib/foundry-devops
	url = https://github.com/Cyfrin/foundry-devops
[submodule "contracts/lib/modulekit"]
	path = contracts/lib/modulekit
	url = https://github.com/rhinestonewtf/modulekit
[submodule "contracts/lib/webauthn-sol"]
	path = contracts/lib/webauthn-sol
	url = https://github.com/base/webauthn-sol
