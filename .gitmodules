[submodule "contracts/lib/foundry-devops"]
	path = contracts/lib/foundry-devops
	url = https://github.com/Cyfrin/foundry-devops
[submodule "contracts/lib/modulekit"]
	path = contracts/lib/modulekit
	url = https://github.com/rhinestonewtf/modulekit
[submodule "contracts/lib/webauthn-sol"]
